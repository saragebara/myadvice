<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<!-- MAIN CONTROLLER : SIDEBAR AND CENTER PANE -->

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sad.myadvice.advising.ui.MainController"
            prefWidth="1000" prefHeight="680"
            style="-fx-background-color: #F0F2F5;">

    <left>
    <!-- Dynamic sidebar that changes depending on the user's role -->
        <VBox fx:id="sidebar"
              spacing="8"
              style="-fx-background-color: #003366; -fx-min-width: 210; -fx-padding: 24 16 24 16;">

            <Label text="myAdvice"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="University of Windsor"
                   style="-fx-font-size: 11; -fx-text-fill: #CCCCCC;"/>
            <Region style="-fx-background-color: #FFCC00; -fx-min-height: 3; -fx-max-height: 3;"
                    maxWidth="Infinity"/>
            <Label fx:id="sidebarRoleLabel"
                   text="Portal"
                   style="-fx-font-size: 11; -fx-text-fill: #CCCCCC; -fx-padding: 4 0 8 0;"/>

            <!-- Buttons are now injected dynamically by MainController instead of manually added -->
            <VBox fx:id="sidebarButtons" spacing="8" VBox.vgrow="ALWAYS"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Region style="-fx-background-color: #FFCC00; -fx-min-height: 3; -fx-max-height: 3;"
                    maxWidth="Infinity"/>
            <Label fx:id="sidebarUserLabel"
                   text=""
                   style="-fx-font-size: 10; -fx-text-fill: #CCCCCC; -fx-padding: 4 0 0 0;"/>
        </VBox>
    </left>

<!-- MAIN CONTENT PANE -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #F0F2F5; -fx-border-color: transparent;">
            <content>
                <StackPane fx:id="contentArea"
                           style="-fx-background-color: #F0F2F5;"/>
            </content>
        </ScrollPane>
    </center>

</BorderPane>