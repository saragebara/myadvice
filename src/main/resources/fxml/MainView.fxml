<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sad.myadvice.advising.ui.MainController"
            prefWidth="900" prefHeight="600">

    <!-- Sidebar -->
    <left>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #2E5FA3; -fx-min-width: 180;">
            <Label text="myAdvice" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Student Portal" style="-fx-text-fill: #cccccc; -fx-font-size: 11;"/>
            <Separator style="-fx-background-color: #ffffff;"/>
            <Button fx:id="btnProgress" text="My Progress" onAction="#showProgress"
                    maxWidth="Infinity" style="-fx-background-color: #1F3864; -fx-text-fill: white;"/>
            <Button fx:id="btnEligible" text="Eligible Courses" onAction="#showEligible"
                    maxWidth="Infinity" style="-fx-background-color: #1F3864; -fx-text-fill: white;"/>
            <Button fx:id="btnCourseDetails" text="Course Details" onAction="#showCourseDetails"
                    maxWidth="Infinity" style="-fx-background-color: #1F3864; -fx-text-fill: white;"/>
            <Button fx:id="btnPlans" text="My Plans" onAction="#showPlans"
                    maxWidth="Infinity" style="-fx-background-color: #1F3864; -fx-text-fill: white;"/>
        </VBox>
    </left>

    <!-- Main content area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 20;"/>
    </center>

</BorderPane>